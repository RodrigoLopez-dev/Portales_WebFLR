DirectoryIndex index.php
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /project-manager/

    # Servir recursos estáticos desde /public usando /assets
    RewriteRule ^assets/(.*)$ public/$1 [L,NC]

    # Si no existe archivo o directorio físico, enviar al front controller
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>
